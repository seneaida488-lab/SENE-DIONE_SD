# --- Compilateur et options ---
CC      = gcc
CFLAGS  = -Wall -Wextra -I include -I benchmark
LDFLAGS = -lm

# --- Dossiers ---
SRC       = src
BEN       = benchmark
INC       = include
GRAPHS    = graphs

# --- Fichiers sources communs ---
SRCS_COMMUNS = $(SRC)/structure.c \
               $(SRC)/tableau_statique.c \
               $(SRC)/tableau_dynamique.c \
               $(SRC)/liste_chainee.c

# ============================================================
# CIBLE PAR DEFAUT : compiler tout
# ============================================================
all: structure bench main_statique main_dynamique main_liste

# ============================================================
# PROGRAMME PRINCIPAL au menu interactif scolarité
# ============================================================
structure: $(SRCS_COMMUNS) $(BEN)/main_structure.c
	$(CC) $(CFLAGS) -o structure \
		$(SRCS_COMMUNS) \
		$(BEN)/main_structure.c \
		$(LDFLAGS)
	@echo ">>> structure compilé"

# ============================================================
# BENCHMARK au mesure des temps d'exécution
# ============================================================
bench: $(SRCS_COMMUNS) $(BEN)/generateur_donnee.c $(BEN)/main.c
	$(CC) $(CFLAGS) -o bench \
		$(SRCS_COMMUNS) \
		$(BEN)/generateur_donnee.c \
		$(BEN)/main.c \
		$(LDFLAGS)
	@echo ">>> bench compilé"

# ============================================================
# MAIN TABLEAU STATIQUE
# ============================================================
main_statique: $(SRCS_COMMUNS) $(BEN)/main_statique.c
	$(CC) $(CFLAGS) -o main_statique \
		$(SRCS_COMMUNS) \
		$(BEN)/main_statique.c \
		$(LDFLAGS)
	@echo ">>> main_statique compilé"

# ============================================================
# MAIN TABLEAU DYNAMIQUE
# ============================================================
main_dynamique: $(SRCS_COMMUNS) $(BEN)/main_dynamique.c
	$(CC) $(CFLAGS) -o main_dynamique \
		$(SRCS_COMMUNS) \
		$(BEN)/main_dynamique.c \
		$(LDFLAGS)
	@echo ">>> main_dynamique compilé"

# ============================================================
# MAIN LISTE DOUBLEMENT CHAINNE
# ============================================================
main_liste: $(SRCS_COMMUNS) $(BEN)/main_liste.c
	$(CC) $(CFLAGS) -o main_liste \
		$(SRCS_COMMUNS) \
		$(BEN)/main_liste.c \
		$(LDFLAGS)
	@echo ">>> main_liste compilé"

# ============================================================
# LANCER LE BENCHMARK ET GENERER LES COURBES
# ============================================================
run_bench: bench
	./bench
	@echo ">>> Benchmark terminé au résultats dans resultats_benchmark.csv"

courbes: run_bench
	cd $(GRAPHS) && python main.py
	@echo ">>> Courbes générées dans graphs/"

# ============================================================
# NETTOYAGE
# ============================================================
clean:
	rm -f structure bench main_statique main_dynamique main_liste
	rm -f *.bin *.csv
	rm -f $(GRAPHS)/*.png
	@echo ">>> Nettoyage terminé"

# ============================================================
# AIDE
# ============================================================
help:
	@echo "Cibles disponibles :"
	@echo "  make all           au compile tout"
	@echo "  make structure     au compile le menu interactif"
	@echo "  make bench         au compile le benchmark"
	@echo "  make main_statique au compile le main tableau statique"
	@echo "  make main_dynamique au compile le main tableau dynamique"
	@echo "  make main_liste    au compile le main liste chainée"
	@echo "  make run_bench     au lance le benchmark"
	@echo "  make courbes       au lance benchmark + génére les courbes"
	@echo "  make clean         au supprime les exécutables et fichiers générés"

.PHONY: all structure bench main_statique main_dynamique main_liste \
        run_bench courbes clean help