# --- Compilateur et options ---
CC      = gcc
CFLAGS  = -Wall -Wextra -I include -I benchmark
LDFLAGS = -lm

# --- Dossiers ---
SRC       = src
BEN       = benchmark
INC       = include
GRAPHS    = graphs

# --- Fichiers sources communs ---
SRCS_COMMUNS = $(SRC)/structure.c \
               $(SRC)/tableau_statique.c \
               $(SRC)/tableau_dynamique.c \
               $(SRC)/liste_chainee.c

# ============================================================
# CIBLE PAR DÉFAUT : compiler tout
# ============================================================
all: main_structure main_bench main_statique main_dynamique main_liste main_unique

# ============================================================
# PROGRAMME PRINCIPAL — menu interactif scolarité
# ============================================================
main_structure: $(SRCS_COMMUNS) $(BEN)/main_structure.c
	$(CC) $(CFLAGS) -o structure \
		$(SRCS_COMMUNS) \
		$(BEN)/main_structure.c \
		$(LDFLAGS)
	@echo ">>> main_structure compilé"

# ============================================================
# BENCHMARK — mesure des temps d'exécution
# ============================================================
main_bench: $(SRCS_COMMUNS) $(BEN)/generateur_donnee.c $(BEN)/main.c
	$(CC) $(CFLAGS) -o bench \
		$(SRCS_COMMUNS) \
		$(BEN)/generateur_donnee.c \
		$(BEN)/main_bench.c \
		$(LDFLAGS)
	@echo ">>> main_bench compilé"

# ============================================================
# MAIN TABLEAU STATIQUE
# ============================================================
main_statique: $(SRCS_COMMUNS) $(BEN)/main_statique.c
	$(CC) $(CFLAGS) -o main_statique \
		$(SRCS_COMMUNS) \
		$(BEN)/main_statique.c \
		$(LDFLAGS)
	@echo ">>> main_statique compilé"

# ============================================================
# MAIN TABLEAU DYNAMIQUE
# ============================================================
main_dynamique: $(SRCS_COMMUNS) $(BEN)/main_dynamique.c
	$(CC) $(CFLAGS) -o main_dynamique \
		$(SRCS_COMMUNS) \
		$(BEN)/main_dynamique.c \
		$(LDFLAGS)
	@echo ">>> main_dynamique compilé"

# ============================================================
# MAIN LISTE DOUBLEMENT CHAÎNÉE
# ============================================================
main_liste: $(SRCS_COMMUNS) $(BEN)/main_liste.c
	$(CC) $(CFLAGS) -o main_liste \
		$(SRCS_COMMUNS) \
		$(BEN)/main_liste.c \
		$(LDFLAGS)
	@echo ">>> main_liste compilé"

# ============================================================
# MAIN UNIQUE — regroupe les 3 structures dans un seul menu
# ============================================================
main_unique: $(SRCS_COMMUNS) $(BEN)/generateur_donnee.c $(BEN)/main_unique.c
	$(CC) $(CFLAGS) -o main_unique \
		$(SRCS_COMMUNS) \
		$(BEN)/generateur_donnee.c \
		$(BEN)/main_unique.c \
		$(LDFLAGS)
	@echo ">>> main_unique compilé"

# ============================================================
# LANCER LE BENCHMARK ET GÉNÉRER LES COURBES
# ============================================================
run_bench: bench
	./bench
	@echo ">>> Benchmark terminé — résultats dans resultats_benchmark.csv"

courbes: run_bench
	cd $(GRAPHS) && python main.py
	@echo ">>> Courbes générées dans graphs/"

# ============================================================
# NETTOYAGE
# ============================================================
clean:
	rm -f main_structure main_ssbench main_statique main_dynamique main_liste main_unique
	rm -f *.bin *.csv
	rm -f $(GRAPHS)/*.png
	@echo ">>> Nettoyage terminé"

# ============================================================
# AIDE
# ============================================================
help:
	@echo "Cibles disponibles :"
	@echo "  make all           — compile tout"
	@echo "  make structure     — compile le menu interactif"
	@echo "  make bench         — compile le benchmark"
	@echo "  make main_statique — compile le main tableau statique"
	@echo "  make main_dynamique— compile le main tableau dynamique"
	@echo "  make main_liste    — compile le main liste chaînée"
	@echo "  make run_bench     — lance le benchmark"
	@echo "  make courbes       — lance benchmark + génère les courbes"
	@echo "  make clean         — supprime les exécutables et fichiers générés"

.PHONY: all main_structure main_bench main_statique main_dynamique main_liste main_unique \
        run_bench courbes clean help